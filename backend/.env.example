# Database Configuration
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=booking_system

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_very_long_secure_secret_key_min_32_characters_long_here
JWT_EXPIRE=7d
PASSWORD_RESET_EXPIRE=15m

# CORS Configuration
FRONTEND_URL=http://localhost:3000

# Google Login Configuration
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# Optional: support multiple client IDs (comma-separated) for web/mobile
GOOGLE_CLIENT_IDS=

# OpenAI Chatbot Fallback (Optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# SMTP / Email Configuration (Required for real email sending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=BeautyBook <your_email@gmail.com>
SMTP_REPLY_TO=

# Legacy aliases (still supported by backend/src/services/mailService/index.js)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_FROM=BeautyBook <your_email@gmail.com>
EMAIL_REPLY_TO=
SUPPORT_EMAIL=support@beautybook.vn

# Payment Configuration
MOMO_API_KEY=your_momo_api_key
MOMO_PARTNER_CODE=your_partner_code
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
BACKEND_PUBLIC_URL=http://localhost:5000
FRONTEND_PAYMENT_RETURN_URL=http://localhost:3000/payment-result
VIETQR_BANK_BIN=970405
VIETQR_BANK_NAME=Agribank
VIETQR_ACCOUNT_NO=your_receiver_account_no
VIETQR_ACCOUNT_NAME=your_account_holder_name
VIETQR_TEMPLATE=compact2
VIETQR_EXPIRE_SECONDS=300
VIETQR_EXPIRE_MINUTES=720

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5
